{
  "version": "2.0",
  "logging": {
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Exception"
      },
      "enableLiveMetricsFilters": true
    },
    "logLevel": {
      "Microsoft.Hosting.Lifetime": "Warning"
    }
  },
  "extensions": {
    "serviceBus": {
      "maxConcurrentCalls": 8,
      "maxAutoLockRenewalDuration": "00:10:00",
      "autoCompleteMessages": true
    }
  }
}
